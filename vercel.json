{
  "builds": [
    {
      "src": "api/chat.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/chat.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/chat.py"
    },
    {
      "src": "/",
      "dest": "static/chat.html"
    },
    {
      "src": "/(.*)",
      "dest": "static/chat.html"
    }
  ]
}
